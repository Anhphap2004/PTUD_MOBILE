<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- AVATAR -->
        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/edittext_bg"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary_blue" />

        <!-- NAME -->
        <TextView
            android:id="@+id/tvStudentName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="LÊ TRỌNG NGHĨA"
            app:layout_constraintStart_toEndOf="@id/imgAvatar"
            app:layout_constraintTop_toTopOf="@id/imgAvatar"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MSSV -->
        <TextView
            android:id="@+id/tvStudentId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="MSSV: 225748020110313"
            app:layout_constraintStart_toEndOf="@id/imgAvatar"
            app:layout_constraintTop_toBottomOf="@id/tvStudentName"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- EXTRA INFO -->
        <TextView
            android:id="@+id/tvExtraInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:text="K63 • CNTT"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/imgAvatar"
            app:layout_constraintTop_toBottomOf="@id/tvStudentId"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BUTTON GROUP -->
        <LinearLayout
            android:id="@+id/layoutButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgAvatar">

            <!-- BUTTON VẮNG -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAbsent"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="90dp"
                android:layout_height="42dp"
                android:text="Vắng"
                android:textAllCaps="false"
                android:textColor="#FF4B4B"
                android:textStyle="bold"
                app:backgroundTint="#3D2323"
                app:cornerRadius="12dp" />

            <!-- BUTTON CÓ MẶT -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPresent"
                android:layout_width="100dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:text="Có mặt"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/accent_green"
                app:cornerRadius="12dp" />

            <!-- BUTTON CẤP GCN -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIssueCert"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:text="Cấp GCN"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <!-- STATUS -->
        <TextView
            android:id="@+id/tvAttendanceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/edittext_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="CÓ MẶT"
            android:textColor="@color/accent_green"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@id/layoutButtons"
            app:layout_constraintStart_toEndOf="@id/layoutButtons"
            app:layout_constraintTop_toTopOf="@id/layoutButtons" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>