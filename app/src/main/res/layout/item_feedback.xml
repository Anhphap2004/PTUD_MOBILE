<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider_color"
    app:strokeWidth="1.2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- AVATAR -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivFeedbackAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/avataadmin"
            android:scaleType="centerCrop"
            android:padding="2dp"
            android:background="@drawable/edittext_bg"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- USER NAME -->
        <TextView
            android:id="@+id/tvFeedbackUserName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/primary_blue"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivFeedbackAvatar"
            app:layout_constraintTop_toTopOf="@id/ivFeedbackAvatar"
            tools:text="Lê Trọng Nghĩa (SINH VIÊN)" />

        <!-- TIMESTAMP -->
        <TextView
            android:id="@+id/tvFeedbackTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvFeedbackUserName"
            app:layout_constraintTop_toBottomOf="@id/tvFeedbackUserName"
            tools:text="14/06/2026 15:03" />

        <!-- DIVIDER -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/divider_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivFeedbackAvatar" />

        <!-- MESSAGE CONTENT -->
        <TextView
            android:id="@+id/tvFeedbackContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintEnd_toStartOf="@+id/btnDeleteFeedback"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"
            tools:text="Nội dung tin nhắn hỗ trợ từ người dùng... hihi haha" />

        <ImageButton
            android:id="@+id/btnDeleteFeedback"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#FF4B4B"
            app:layout_constraintBottom_toBottomOf="@+id/tvFeedbackContent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvFeedbackContent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>